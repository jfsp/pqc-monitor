# PQC-Monitor Configuration
# SPDX-License-Identifier: GPL-3.0-or-later
# Copy to config.yaml and edit

shodan:
  api_key: ""          # Set your Shodan API key here; leave empty for direct scanning

scanning:
  timeout: 10          # seconds per connection attempt
  max_workers: 20      # parallel scan threads
  ports:               # TLS-bearing ports to probe
    - 443              # HTTPS
    - 8443             # Alt HTTPS
    - 465              # SMTPS (implicit TLS)
    - 993              # IMAPS (implicit TLS)
    - 995              # POP3S (implicit TLS)
    - 636              # LDAPS
    - 5061             # SIP-TLS
  # STARTTLS ports (25 SMTP, 587/2525 submission, 143 IMAP, 110 POP3) are
  # probed automatically via protocol upgrade when use_starttls is true.
  use_starttls: true
  user_agent: "PQCMonitor/1.0 (security research; non-intrusive)"

dashboard:
  host: "127.0.0.1"
  port: 5000
  secret_key: "change-me-in-production"
  # Set https_enabled to true ONLY when a TLS-terminating reverse proxy
  # (nginx, Caddy) is in front. When false (default), session cookies work
  # over plain HTTP so the app is reachable during initial setup.
  # Running in production without TLS is not recommended.
  https_enabled: false

scheduler:
  default_interval_days: 90   # every ~3 months

database:
  # Production: /var/lib/pqc-monitor/pqc_monitor.db (set by install.sh)
  # Development: leave as-is (relative to project root)
  path: "data/pqc_monitor.db"

ai:
  anthropic_api_key: ""       # For natural-language domain discovery
  model: "claude-sonnet-4-20250514"

dns_enumeration:
  # DNSDumpster integration for subdomain discovery.
  # Leave api_key blank to disable DNSDumpster (recommended default).
  # Obtain a key at https://dnsdumpster.com/api/
  # Can also be set via the PQC_DNSDUMPSTER_KEY environment variable.
  dnsdumpster_api_key: ""
  use_wordlist: true          # built-in 120-prefix brute-force
  use_ct: true                # crt.sh Certificate Transparency harvest

ssllabs:
  # Qualys SSL Labs API v4 integration (grade shown in domain detail;
  # display only — does not affect the PQC score).
  # Requires a ONE-TIME registration with an organisational email
  # (Gmail/Yahoo/Hotmail are rejected by Qualys):
  #   python3 -c "from scanner.ssllabs_client import register_email; \
  #               print(register_email('First','Last','Org','you@org.example'))"
  # The registered email is sent as the auth header on every API call.
  # Can also be set via the PQC_SSLLABS_EMAIL environment variable.
  # Leave email blank to disable the integration.
  enabled: true
  email: ""

guidelines:
  active:
    - nist_800_131a
    - bsi_tr02102
    - ccn_stic_221

logging:
  level: INFO
  # Production: /var/log/pqc-monitor/pqc_monitor.log (set by install.sh)
  # Development: relative to project root
  file: "data/pqc_monitor.log"
