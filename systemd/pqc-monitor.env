# PQC-Monitor: Environment Configuration
# Copy to /etc/pqc-monitor/pqc-monitor.env and edit.
# File permissions must be 640, owner root:pqcmonitor.
#
# IMPORTANT: This file contains secrets. Never commit it to version control.
#
# sudo install -m 640 -o root -g pqcmonitor \
#     systemd/pqc-monitor.env /etc/pqc-monitor/pqc-monitor.env
#
# SPDX-License-Identifier: GPL-3.0-or-later

# ── Required ──────────────────────────────────────────────────────────────────

# Secret key for Flask session signing.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
PQC_SECRET_KEY=change-this-to-a-random-64-character-hex-string

# Absolute path to the YAML config file.
PQC_CONFIG=/opt/pqc-monitor/config/config.yaml

# ── Network ───────────────────────────────────────────────────────────────────

# Address and port for Gunicorn to listen on.
# Use 127.0.0.1:5000 when behind a reverse proxy (recommended).
# Use 0.0.0.0:5000 only if directly internet-facing (not recommended).
PQC_BIND=127.0.0.1:5000

# Number of Gunicorn worker processes.
# Rule of thumb: (2 × CPU cores) + 1. For a 2-core VM: 5.
PQC_WEB_WORKERS=3

# ── Optional API keys ─────────────────────────────────────────────────────────

# Shodan API key — leave empty to use direct TCP scanning
SHODAN_API_KEY=

# Anthropic API key — required for AI-powered domain discovery
ANTHROPIC_API_KEY=
